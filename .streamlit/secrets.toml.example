# 이 파일은 참고용 예제입니다.
# 실제 사용 시:
#   1) 로컬: 이 파일을 secrets.toml 로 복사 후 실제 키 입력 (gitignore 됨)
#   2) Streamlit Cloud: 대시보드 → Settings → Secrets 에 아래 내용 붙여넣기
#
# 이 앱은 로컬 .env 파일의 OPENAI_API_KEY 도 지원합니다.
# 우선순위: .env > 시스템 환경변수 > st.secrets

# ── (1) OpenAI (필수) — LLM 응답 생성 ──
OPENAI_API_KEY = "sk-proj-여기에_실제_키_붙여넣기"

# ── (2) 네이버 뉴스 검색 API (선택, 없으면 Google News RSS 자동 폴백) ──
# 발급: https://developers.naver.com/apps/#/register
#   1) 로그인 → "애플리케이션 등록" 클릭
#   2) 사용 API에 "검색" 체크 → 사용 환경은 "WEB 설정"만 선택
#   3) 등록 완료 후 Client ID / Client Secret 복사
NAVER_CLIENT_ID = "네이버_개발자센터_ClientID"
NAVER_CLIENT_SECRET = "네이버_개발자센터_ClientSecret"
